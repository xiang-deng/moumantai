# Moumantai server SECRETS
#
# This file is a TEMPLATE. The real .env that the server reads lives in your
# Moumantai workspace. Resolution order (first match wins):
#
#   1. $MOUMANTAI_HOME/.env             (explicit override)
#   2. <repo>/.moumantai/.env           (project-local dev — preferred for repo work)
#   3. ~/.moumantai/.env                (global default)
#
# Run `task server:cli -- init` (or `tsx src/server/cli.ts init`) from the
# repo root to walk through a guided setup. The wizard creates `.moumantai/`
# at the repo root, validates your credential, and writes it to
# `.moumantai/.env` securely. Both Anthropic auth methods are accepted; the
# wizard picks the right env var by prefix:
#   sk-ant-oat… → CLAUDE_CODE_OAUTH_TOKEN
#   sk-ant-api… → ANTHROPIC_API_KEY
#
# This file is for SECRETS ONLY. Non-secret tunables (port, voice models,
# etc.) live in <home>/config.json — view with `task server:cli --
# config show`, edit with `task server:cli -- config edit`.
#
# ---------------------------------------------------------------------------
# Anthropic auth (pick one)
# ---------------------------------------------------------------------------

# Option 1: OAuth token from Claude Pro/Max subscription (run: claude setup-token)
#CLAUDE_CODE_OAUTH_TOKEN=

# Option 2: API key from https://console.anthropic.com
#ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Voice (STT + TTS via OpenAI). Optional — server uses a mock audio service
# when this is unset.
# ---------------------------------------------------------------------------

#OPENAI_API_KEY=
